# LLM routing
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4.1-mini
LLM_PROMPT_VERSION=v1

# OpenRouter credentials
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=lunduke-transcripts

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Feature toggles
ENABLE_CLEANUP=false
ENABLE_ARTICLE=false

# Timeout/retry tuning
YT_DLP_TIMEOUT_SECONDS=120
LLM_TIMEOUT_SECONDS=60
LLM_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=2

# Optional lee-llm-router override for selected tutorial tasks
LLM_ROUTER_ENABLED=false
LLM_ROUTER_REPO_PATH=/Users/leeharrington/projects/lee-llm-router
LLM_ROUTER_CONFIG_PATH=config/tutorial-llm-router.yaml
LLM_ROUTER_TRACE_DIR=
