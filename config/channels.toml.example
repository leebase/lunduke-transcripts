[app]
data_dir = "data"
default_language = "en"
timezone = "America/Chicago"
enable_cleanup = true
enable_article = false
yt_dlp_binary = "yt-dlp"
yt_dlp_timeout_seconds = 120
fetch_retries = 2
retry_backoff_seconds = 2
max_videos_per_channel = 40
enable_asr_fallback = false
force_asr = false
asr_provider = "fast-whisper"
asr_model = "small.en"
asr_device = "auto"
asr_compute_type = "auto"
ffmpeg_binary = "ffmpeg"
ffprobe_binary = "ffprobe"
ffmpeg_timeout_seconds = 300
keep_audio_files = false
frame_capture_enabled = true
frame_capture_threshold = 0.25
frame_image_format = "jpg"
pandoc_binary = "pandoc"
pdf_engine = "chromium"
pdf_engine_binary = "chromium"

[llm]
provider = "openrouter"
model = "openai/gpt-4.1-mini"
prompt_version = "v1"
timeout_seconds = 120
retries = 2
retry_backoff_seconds = 2
router_enabled = false
router_repo_path = "/Users/leeharrington/projects/lee-llm-router"
router_config_path = "config/tutorial-llm-router.yaml"

[llm.router_roles]
"tutorial.educator" = "tutorial_educator"
"tutorial.source-interpretation" = "tutorial_interpreter"
"tutorial.planner" = "tutorial_planner"
"tutorial.evidence" = "tutorial_evidence"
"tutorial.visual" = "tutorial_visual"
"tutorial.writer" = "tutorial_writer"
"tutorial.technical-review" = "tutorial_reviewer"

[[channels]]
name = "Example Journalist"
url = "https://www.youtube.com/@example/videos"
language = "en"

[[videos]]
name = "Example Single Video"
url = "https://www.youtube.com/watch?v=VIDEO_ID"
language = "en"
clip_start = "00:30:40"
clip_end = "01:12:35"
force_asr = true

[[files]]
name = "Example Local Video"
path = "/absolute/path/to/demo.mp4"
language = "en"
clip_start = "00:00:00"
clip_end = "00:05:00"
force_asr = false
